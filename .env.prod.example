# 生产环境配置模板 — 华为云 RDS PostgreSQL 主备 + 单容器 Redis
#
# 使用方式：
#   cp .env.prod.example .env.prod  （然后替换所有 <占位符> 为真实值）
#   docker compose --env-file .env.prod up -d
#
# 说明：
#   postgres 容器有 profiles: [local]，生产启动时不会启动 postgres 容器
#   redis 仍为本机容器（服务名 redis）
#   本文件提交到 git；.env.prod 本身不提交（已加入 .gitignore）

# PostgreSQL — 华为云 RDS 主备版
# 注意事项：
#   1. 华为云 RDS 强制 SSL，连接串末尾必须加 ?sslmode=require
#   2. 华为云控制台数据库名不允许中划线，使用下划线：new_api
#   3. 密码中若含 @ 需编码为 %40；+ 号可直接使用无需编码
#   4. 生成密码建议：openssl rand -base64 24（避免 @ 字符）
SQL_DSN=postgresql://<DB_USER>:<DB_PASSWORD>@<RDS_HOST>:5432/new_api?sslmode=require

# Redis — 本机容器（服务名 redis，与 docker-compose.yml 中一致）
REDIS_CONN_STRING=redis://redis

# Session 密钥 — 必须固定，重启容器后保持不变，否则所有用户需重新登录
# 生成方式：openssl rand -hex 32
SESSION_SECRET=<openssl rand -hex 32 生成的值>

# Watchtower 在线升级令牌 — 与 docker-compose.yml 中 WATCHTOWER_HTTP_API_TOKEN 一致
# 生成方式：openssl rand -hex 32
WATCHTOWER_API_TOKEN=<openssl rand -hex 32 生成的值>

# 节点名 — 多节点部署时每台填不同值，用于审计日志区分来源
NODE_NAME=new-api-node-1

# 反向代理子网 — WAF/Nginx 所在子网 CIDR，用于从 X-Forwarded-For 获取用户真实 IP
# 多个子网用逗号分隔，留空则不信任任何代理（直连部署时留空）
TRUSTED_PROXY_CIDR=10.0.0.0/24

# 端口绑定地址 — 生产环境通过安全组/WAF 控制访问来源时设为 0.0.0.0
# 本地开发默认 127.0.0.1（docker-compose.yml 中已设默认值，此行可省略）
BIND_HOST=0.0.0.0

# Streaming 无响应超时（秒）— 上游 AI 停止返回 token 后等待多久断开
# 默认 120s；接入 DeepSeek R1 等深度思考模型时建议设为 300
STREAMING_TIMEOUT=300
